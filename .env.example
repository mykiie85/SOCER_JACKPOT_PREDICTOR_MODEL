# Copy to .env and fill in. Same variable names as EdgeBot, so you can also
# just symlink/copy EdgeBot's .env and add EDGEBOT_PATH.

# Where the trained EdgeBot checkout lives (models + data_cache)
EDGEBOT_PATH=C:\Users\mykii\Downloads\Betting algorithim
# Linux VPS example:
# EDGEBOT_PATH=/home/edgebot/edgebot

# Telegram (reuse EdgeBot's bot or a dedicated one). Multiple chat ids: comma-separated.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail SMTP (app password, not the account password)
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# Optional overrides
# JACKPOT_API_BASE=https://jackpot-offer-api.sportpesa.co.tz/api
# DATA_DIR=/home/edgebot/jackpot_predictor/data
